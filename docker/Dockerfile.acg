# =============================================================================
# agent-chat-gateway — ACG Docker Image
#
# Includes: Python 3.12, uv, Claude Code (npm), OpenCode, ACG installed
#
# Build (from repo root):
#   docker build -f docker/Dockerfile.acg -t acg:latest .
#
# Run:
#   docker run -e RC_URL=... -e RC_USERNAME=... -e RC_PASSWORD=... \
#              -e ACG_OWNER_USERS=alice \
#              -e ANTHROPIC_API_KEY=sk-ant-... \
#              acg:latest
# =============================================================================

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Tell Claude Code it's running in a sandboxed/container environment.
# This disables interactive permission prompts and may bypass features
# that require direct Anthropic API (e.g. context-management-2025-06-27),
# allowing OpenRouter or other compatible providers to work.
ENV IS_SANDBOX=1

# -----------------------------------------------------------------------------
# System dependencies
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# Node.js 20 LTS — required for Claude Code
# -----------------------------------------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# uv — Python package manager (also installs Python 3.12 if system lacks it)
# -----------------------------------------------------------------------------
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:/root/.cargo/bin:/root/.opencode/bin:$PATH"

# -----------------------------------------------------------------------------
# Claude Code CLI
# -----------------------------------------------------------------------------
RUN npm install -g @anthropic-ai/claude-code

# -----------------------------------------------------------------------------
# OpenCode CLI
# -----------------------------------------------------------------------------
RUN curl -fsSL https://opencode.ai/install | bash

# -----------------------------------------------------------------------------
# Install ACG — mirrors the real curl | bash install flow exactly:
#   repo → ~/.agent-chat-gateway/repo  (same as curl | bash)
#
# Benefits:
#   1. install_meta.json points to ~/.agent-chat-gateway/repo — upgrade works
#   2. Docker build validates install.sh in the same path as real installs
#   3. `agent-chat-gateway upgrade` can be run inside the container
# -----------------------------------------------------------------------------
COPY . /root/.agent-chat-gateway/repo
RUN bash /root/.agent-chat-gateway/repo/install.sh --no-onboard

# -----------------------------------------------------------------------------
# Pre-create all mountable directories
#
# Volume mount points:
#
#   ~/.agent-chat-gateway/config/   — ONLY config.yaml + .env (safe to bind-mount;
#                                      entrypoint symlinks them one level up)
#   ~/.agent-chat-gateway/work/      — agent working directory (inspectable locally)
#   ~/.agent-chat-gateway/contexts/  — custom context files (defaults restored if empty)
#   ~/.claude/                       — Claude Code config & auth (settings.json, CLAUDE.md)
#   ~/.config/opencode/              — OpenCode config & API key (config.json)
#
# NOTE: do NOT bind-mount ~/.agent-chat-gateway directly — it contains
# install_meta.json and contexts required at runtime.
# -----------------------------------------------------------------------------
RUN mkdir -p \
    /root/.agent-chat-gateway/config \
    /root/.agent-chat-gateway/work \
    /root/.agent-chat-gateway/logs \
    /root/.agent-chat-gateway/data \
    /root/.claude \
    /root/.config/opencode

# -----------------------------------------------------------------------------
# Entrypoint — generates config.yaml + .env from env vars, starts daemon
# -----------------------------------------------------------------------------
COPY docker/entrypoint.acg.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
